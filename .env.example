# DocuMind Environment Variables
# Copy this file to .env and fill in your API keys

# Google Gemini API Key (Required for fact verification in self-learning mode)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Operation Mode (optional - can also be selected at startup)
# Options: "local" (privacy-focused) or "self-learning" (full features)
DOCUMIND_MODE=self-learning
